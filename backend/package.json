{
  "name": "arte-em-ponto-admin-server",
  "version": "1.0.0",
  "description": "Backend API for Recicloth admin panel",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch src/index.ts",
    "build": "node build.js",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "start:dev": "cross-env NODE_ENV=development node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx src/database/runMigrations.ts",
    "cleanup-tokens": "tsx src/cleanup-tokens.ts",
    "migrate-images": "tsx src/migrate-images-to-disk.ts",
    "generate-image-variants": "tsx src/generate-image-variants.ts",
    "generate-hero-slide-variants": "tsx src/generate-hero-slide-variants.ts",
    "migrate-i18n": "tsx src/migrate-i18n.ts"
  },
  "keywords": [
    "admin",
    "api",
    "ecommerce"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1018.0",
    "@aws-sdk/s3-request-presigner": "^3.1018.0",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "geoip-lite": "^1.4.10",
    "google-auth-library": "^10.4.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^7.0.10",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.16.3",
    "resend": "^6.9.2",
    "sharp": "^0.34.4",
    "stripe": "^20.4.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/geoip-lite": "^1.4.4",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^6.4.21",
    "@types/pg": "^8.15.5",
    "cross-env": "^10.1.0",
    "esbuild": "^0.27.0",
    "tsx": "^4.20.6",
    "typescript": "^5.5.3"
  }
}
