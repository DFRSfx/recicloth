PORT=3001
NODE_ENV=development
# Localhost: development
# Vercel: production

# PostgreSQL / Supabase
DB_HOST=aws-1-eu-west-1.pooler.supabase.com
DB_PORT=5432
DB_USER=postgres.orekmrlxkpuymngiphzf
DB_PASSWORD=your_supabase_password
DB_NAME=postgres
DB_SSL=false
# Vercel/Supabase production: set DB_SSL=true
DB_POOL_MAX=2
DB_IDLE_TIMEOUT_MS=10000
DB_CONNECTION_TIMEOUT_MS=5000

# JWT
JWT_SECRET=generate_with_crypto_randomBytes_64
JWT_EXPIRES_IN=7d

# Email (Resend API)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM_NAME=Recicloth
EMAIL_FROM=noreply@recicloth.com

# Frontend URL(s), comma-separated for CORS
# Localhost example:
# FRONTEND_URL=http://localhost:5173
# Vercel monodeploy example:
# FRONTEND_URL=https://your-project.vercel.app
FRONTEND_URL=http://localhost:5173

# Google OAuth
# Must be real Google Cloud OAuth credentials for your app.
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Stripe
STRIPE_SECRET_KEY=sk_test_replace_with_your_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_your_webhook_secret

# Supabase S3 Storage (for product images)
# Generate S3 credentials in Supabase: Settings → Storage → S3 Credentials
SUPABASE_S3_ACCESS_KEY=your_access_key_id
SUPABASE_S3_SECRET_KEY=your_secret_access_key
SUPABASE_S3_BUCKET=images-storage
SUPABASE_S3_ENDPOINT=https://your-project-id.storage.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=eu-west-1