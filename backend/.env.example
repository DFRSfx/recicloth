PORT=3001
NODE_ENV=development
# Localhost: development
# Vercel: production

# PostgreSQL / Supabase
DB_HOST=aws-1-eu-west-1.pooler.supabase.com
DB_PORT=5432
DB_USER=postgres.orekmrlxkpuymngiphzf
DB_PASSWORD=your_supabase_password
DB_NAME=postgres
DB_SSL=false

# JWT
JWT_SECRET=generate_with_crypto_randomBytes_64
JWT_EXPIRES_IN=7d

# Email (Resend API)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM_NAME=Recicloth
EMAIL_FROM=noreply@recicloth.com

# Frontend URL(s), comma-separated for CORS
# Localhost example:
# FRONTEND_URL=http://localhost:5173
# Vercel monodeploy example:
# FRONTEND_URL=https://your-project.vercel.app
FRONTEND_URL=http://localhost:5173

# Google OAuth
# Must be real Google Cloud OAuth credentials for your app.
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Stripe
STRIPE_SECRET_KEY=sk_test_replace_with_your_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_your_webhook_secret

# Google Analytics
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
