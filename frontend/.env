# Environment Variables
# Localhost development vs Vercel monodeploy
#
# Localhost:
# - backend at http://localhost:3001
# - use VITE_API_URL=http://localhost:3001
#
# Vercel (frontend + backend in one project/domain):
# - use relative API path (/api)
# - keep VITE_API_URL empty in Vercel environment variables
VITE_API_URL=http://localhost:3001
# VITE_API_URL=

