# Environment Variables
# Copy this file to .env and update with your actual values.
#
# Localhost:
# - frontend calls backend on http://localhost:3001
# - set VITE_API_URL=http://localhost:3001
#
# Vercel monodeploy:
# - frontend + backend share the same domain
# - leave VITE_API_URL empty so app uses relative /api
VITE_API_URL=http://localhost:3001
# VITE_API_URL=

# Google OAuth Client ID
# Get this from: https://console.cloud.google.com/apis/credentials
# Must match backend GOOGLE_CLIENT_ID for OAuth flow.
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Google Analytics 4 (replace with your real Measurement ID)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
