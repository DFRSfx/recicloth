Options -MultiViews -Indexes
RewriteEngine On

# ─── HTTPS redirect ────────────────────────────────────────────────────────────
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ─── www → non-www ─────────────────────────────────────────────────────────────
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# ─── Serve pre-compressed assets (Brotli first, then Gzip) ────────────────────
RewriteCond %{HTTP:Accept-Encoding} br
RewriteCond %{REQUEST_FILENAME}.br -f
RewriteRule ^(.*)$ $1.br [L]

RewriteCond %{HTTP:Accept-Encoding} gzip
RewriteCond %{REQUEST_FILENAME}.gz -f
RewriteRule ^(.*)$ $1.gz [L]

# ─── SPA routing: all non-file routes → index.html ────────────────────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ /index.html [L]

# ─── MIME types + encoding for pre-compressed files ───────────────────────────
<FilesMatch "\.js\.(gz|br)$">
    ForceType application/javascript
</FilesMatch>
<FilesMatch "\.css\.(gz|br)$">
    ForceType text/css
</FilesMatch>

# ─── Cache headers + security headers + encoding headers ──────────────────────
<IfModule mod_headers.c>
    # Pre-compressed encoding
    <FilesMatch "\.gz$">
        Header set Content-Encoding gzip
    </FilesMatch>
    <FilesMatch "\.br$">
        Header set Content-Encoding br
    </FilesMatch>

    # JS/CSS/fonts — Vite hashes filenames so these are safe to cache forever
    <FilesMatch "\.(js|css|woff2?|ttf|eot)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # Images — 30 days
    <FilesMatch "\.(webp|png|jpg|jpeg|gif|ico|svg)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>

    # index.html — never cache
    <FilesMatch "^index\.html$">
        Header set Cache-Control "no-store, no-cache, must-revalidate"
        Header set Pragma "no-cache"
    </FilesMatch>

    # Security headers
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# ─── Gzip compression ──────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE \
        text/plain \
        text/html \
        text/css \
        text/javascript \
        application/javascript \
        application/json \
        application/xml \
        image/svg+xml \
        font/woff \
        font/woff2
</IfModule>

# ─── Block dotfiles ────────────────────────────────────────────────────────────
<FilesMatch "^\.">
    Require all denied
</FilesMatch>
